{
  "manifest_version": 3,
  "name": "Bilibili-Boost",
  "version": "1.3.4",
  "description": "Bilibili-Boost：增强 Bilibili 浏览体验，支持标记看过与播放列表增强",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*.bilibili.com/*"],
  "background": {
    "scripts": ["background.js"],
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bilibili-boost@igniteran.local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Bilibili-Boost",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png",
      "64": "icons/icon64.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.bilibili.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}
